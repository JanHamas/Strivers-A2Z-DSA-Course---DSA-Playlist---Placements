# Outer loop number of = n
# Spaces both   =  n-i
# Character increment by 2 =  i*2-1

def draw_pyramid(n):
    start_char = 'a'
    for i in range(1, n+1):
        chr_ascii = ord(start_char)
        for j in range(1, i*2-1):
            print("hi")
            char = chr(chr_ascii)
            print(char)
            # Increment char
            chr_ascii +=1
            
draw_pyramid(5)
